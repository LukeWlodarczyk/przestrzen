---
import type { JSX } from "astro/jsx-runtime";

import { tw, type PropsWithChildren } from "@utils/index.ts";
import { baseClasses, sizeClasses, variantClasses } from "./Button.classes";

type AllowedTags = "a" | "button";

export type Variant = "primary" | "secondary" | "tertiary" | "nav";
export type Size = "medium" | "large";

interface BaseProps {
  variant?: Variant;
  size?: Size;
  className?: string;
}

export type Props<Tag extends AllowedTags = "a"> =
  PropsWithChildren<BaseProps> &
    Omit<JSX.IntrinsicElements[Tag], "class"> & {
      as?: Tag;
    };

const {
  as: Tag = "a",
  variant = "primary",
  size = "medium",
  className,
  ...attrs
} = Astro.props;
---

<Tag
  class:list={tw(
    baseClasses,
    sizeClasses[size],
    variantClasses[variant],
    className,
  )}
  {...attrs}
>
  {
    variant === "primary" ? (
      <span class="group-focus:shine group-[&:not(:disabled)]:group-hover:shine">
        <slot />
      </span>
    ) : (
      <slot />
    )
  }
</Tag>
